APP_NAME=blesta-wa-reminder
APP_ENV=development
APP_PORT=8080
APP_TIMEZONE=Asia/Jakarta

DATABASE_URL=postgres://postgres:postgres@localhost:5432/blesta_wa_reminder?sslmode=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME_MIN=30

LOG_LEVEL=info

API_BEARER_TOKEN=replace_this_token

ADMIN_BASIC_USER=admin
ADMIN_BASIC_PASS=change_me

DEFAULT_TYPING_DURATION_MS=5000
DEFAULT_DELAY_MIN_SEC=30
DEFAULT_DELAY_MAX_SEC=120
DEFAULT_RETRY_BACKOFF_SEC=300,900,3600
DEFAULT_MAX_ATTEMPTS=3
DEFAULT_DAILY_CAP=40
DEFAULT_HOURLY_CAP=20
DEFAULT_SEND_WINDOW_START=08:00
DEFAULT_SEND_WINDOW_END=20:30

NUMBER_CHECK_CACHE_TTL_HOURS=24
UNREACHABLE_RECHECK_DAYS=7

WORKER_ENABLED=true
WORKER_POLL_INTERVAL_MS=2000
WORKER_BATCH_SIZE=10
WORKER_ID=worker-1

AUTO_MIGRATE=true
